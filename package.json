{
  "name": "backend",
  "version": "1.0.0",
  "description": "An Express.js application",
  "scripts": {
    "swagger": "ts-node -r tsconfig-paths/register swagger/swagger.ts",
    "build": "npm run swagger && tsc && tsc-alias",
    "start": "node dist/server.js",
    "dev": "nodemon --watch src --ext ts --exec \"npm run swagger && ts-node -r tsconfig-paths/register server.ts\"",
    "lint": "eslint . --ext .ts --fix"
  },
  "keywords": [],
  "author": "Anry.Dev",
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "devDependencies": {
    "@eslint/js": "^9.33.0",
    "@tsconfig/node22": "^22.0.2",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/node": "^24.3.0",
    "@types/pg": "^8.20.0",
    "@types/swagger-ui-express": "^4.1.8",
    "add": "^2.0.6",
    "dotenv": "^17.2.1",
    "eslint": "^9.33.0",
    "express": "^5.1.0",
    "globals": "^16.3.0",
    "nodemon": "^3.1.10",
    "pnpm": "^10.14.0",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.17",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.9.2",
    "typescript-eslint": "^8.39.1"
  },
  "dependencies": {
    "cors": "^2.8.6",
    "helmet": "^8.1.0",
    "pg": "^8.21.0",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  }
}
